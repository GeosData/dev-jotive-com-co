---
interface Props {
  title: string;
  description: string;
  url: string;
  icon?: string;
  accentColor?: string;
  featured?: boolean;
  isLab?: boolean;
}

const { title, description, url, icon, accentColor = "emerald", featured = false, isLab = false } = Astro.props;

const labColors: Record<string, string> = {
  emerald: "from-sky-500/15 to-sky-600/5 border-sky-400/40 hover:border-sky-300 hover:from-sky-500/25",
  amber: "from-sky-500/15 to-sky-600/5 border-sky-400/40 hover:border-sky-300 hover:from-sky-500/25",
  rose: "from-sky-500/15 to-sky-600/5 border-sky-400/40 hover:border-sky-300 hover:from-sky-500/25",
  sky: "from-sky-500/15 to-sky-600/5 border-sky-400/40 hover:border-sky-300 hover:from-sky-500/25",
  violet: "from-sky-500/15 to-sky-600/5 border-sky-400/40 hover:border-sky-300 hover:from-sky-500/25",
  zinc: "from-sky-500/15 to-sky-600/5 border-sky-400/40 hover:border-sky-300 hover:from-sky-500/25",
};

const colorClasses: Record<string, string> = {
  emerald: "border-emerald-500/30 hover:border-emerald-400 hover:bg-emerald-500/10",
  amber: "border-amber-500/30 hover:border-amber-400 hover:bg-amber-500/10",
  rose: "border-rose-500/30 hover:border-rose-400 hover:bg-rose-500/10",
  sky: "border-sky-500/30 hover:border-sky-400 hover:bg-sky-500/10",
  violet: "border-violet-500/30 hover:border-violet-400 hover:bg-violet-500/10",
  zinc: "border-zinc-500/30 hover:border-zinc-400 hover:bg-zinc-500/10",
};

const featuredColors: Record<string, string> = {
  emerald: "from-emerald-500/20 to-emerald-600/5 border-emerald-400/50 hover:border-emerald-300 hover:from-emerald-500/30",
  amber: "from-amber-500/20 to-amber-600/5 border-amber-400/50 hover:border-amber-300 hover:from-amber-500/30",
  rose: "from-rose-500/20 to-rose-600/5 border-rose-400/50 hover:border-rose-300 hover:from-rose-500/30",
  sky: "from-sky-500/20 to-sky-600/5 border-sky-400/50 hover:border-sky-300 hover:from-sky-500/30",
  violet: "from-violet-500/20 to-violet-600/5 border-violet-400/50 hover:border-violet-300 hover:from-violet-500/30",
  zinc: "from-zinc-500/20 to-zinc-600/5 border-zinc-400/50 hover:border-zinc-300 hover:from-zinc-500/30",
};
---

<a 
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "group block p-6 border rounded-2xl transition-all duration-300",
    featured 
      ? `bg-gradient-to-br ${featuredColors[accentColor] || featuredColors.zinc}` 
      : isLab
        ? `bg-gradient-to-br ${labColors[accentColor] || labColors.zinc}`
        : "bg-zinc-900/50 backdrop-blur-sm border-zinc-800 hover:border-zinc-600 hover:bg-zinc-800/50"
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-2">
        <h3 class:list={[
          "font-semibold transition-transform duration-300",
          featured ? "text-2xl" : isLab ? "text-xl" : "text-xl"
        ]}>
          {title}
        </h3>
        {featured && (
          <span class="text-xs px-2 py-0.5 rounded-full bg-emerald-500/20 text-emerald-400 border border-emerald-500/30">
            Principal
          </span>
        )}
        {isLab && (
          <span class="text-xs px-2 py-0.5 rounded-full bg-sky-500/20 text-sky-400 border border-sky-500/30">
            Laboratorio
          </span>
        )}
      </div>
      <p class="text-zinc-400 text-sm leading-relaxed">
        {description}
      </p>
    </div>
    {icon && (
      <span class:list={[
        "transition-opacity duration-300",
        featured ? "text-4xl" : isLab ? "text-3xl" : "text-2xl"
      ]}>
        {icon}
      </span>
    )}
  </div>
  <div class="mt-4 flex items-center gap-2 text-xs text-zinc-500 group-hover:text-zinc-300 transition-colors">
    <span>{url.replace('https://', '')}</span>
    <svg class="w-3 h-3 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
    </svg>
  </div>
</a>
