---
/**
 * ContactForm — apuntando a api-emails (mismo endpoint que geosdata.com)
 * Auto-generado desde newsletter-stack/snippets template
 * Source compartido: github.com/GeosData/newsletter-stack
 */

interface Props {
  to?: string;
  subjectPrefix?: string;
  title?: string;
  description?: string;
  ctaText?: string;
}

const {
  to = 'contacto@jotive.com.co',
  subjectPrefix = '[Dev]',
  title = 'Algo que mostrar?',
  description = 'Hablamos sobre Python, GenAI, system design o lo que tengas. Respondo en 2-3 dias.',
  ctaText = 'Enviar mensaje',
} = Astro.props;
const apiKey = import.meta.env.PUBLIC_EMAIL_API_KEY || '';
---

<section class="border-t border-zinc-800/80 bg-zinc-900/30">
  <div class="max-w-3xl mx-auto px-6 py-14">
    <h3 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-3">{title}</h3>
    <p class="text-zinc-400 mb-6 max-w-xl">{description}</p>

    <form class="contact-form max-w-xl" data-to={to} data-subject-prefix={subjectPrefix} data-api-key={apiKey} novalidate>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
        <input type="text" name="name" required autocomplete="name" placeholder="Tu nombre" class="px-4 py-3 rounded-lg bg-zinc-950 border border-zinc-700 text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-sky-500 transition-colors" />
        <input type="email" name="email" required autocomplete="email" placeholder="tu@email.com" class="px-4 py-3 rounded-lg bg-zinc-950 border border-zinc-700 text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-sky-500 transition-colors" />
      </div>
      <input type="text" name="subject" required placeholder="Asunto" class="w-full px-4 py-3 rounded-lg bg-zinc-950 border border-zinc-700 text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-sky-500 transition-colors mb-3" />
      <textarea name="message" required rows="5" placeholder="Tu mensaje..." class="w-full px-4 py-3 rounded-lg bg-zinc-950 border border-zinc-700 text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-sky-500 transition-colors mb-3 resize-y"></textarea>

      <button type="submit" class="px-6 py-3 rounded-lg bg-sky-500 hover:bg-sky-400 text-white font-medium transition-colors disabled:opacity-50 disabled:cursor-wait">
        {ctaText}
      </button>

      <p class="cf-status mt-3 text-sm min-h-[1.25rem]" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('form.contact-form').forEach((form) => {
    const status = form.querySelector<HTMLElement>('.cf-status')!;
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const to = form.dataset.to!;
    const subjectPrefix = form.dataset.subjectPrefix || '[Contacto]';
    const apiKey = form.dataset.apiKey || '';
    const endpoint = 'https://api-emails-448285277410.us-east1.run.app/emails/send';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const name = (data.get('name') as string)?.trim();
      const email = (data.get('email') as string)?.trim();
      const subject = (data.get('subject') as string)?.trim();
      const message = (data.get('message') as string)?.trim();

      if (!name || !email || !subject || !message) {
        status.className = 'cf-status mt-3 text-sm min-h-[1.25rem] text-rose-400';
        status.textContent = 'Completa todos los campos.';
        return;
      }

      status.className = 'cf-status mt-3 text-sm min-h-[1.25rem] text-zinc-400';
      status.textContent = 'Enviando...';
      button.disabled = true;

      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            ...(apiKey && { Authorization: `Bearer ${apiKey}` }),
          },
          body: JSON.stringify({
            to,
            subject: `${subjectPrefix} ${subject}`,
            text: `Nombre: ${name}\nEmail: ${email}\nAsunto: ${subject}\n\nMensaje:\n${message}`,
            html: `<h2>Mensaje de contacto</h2><p><strong>Nombre:</strong> ${name}</p><p><strong>Email:</strong> ${email}</p><p><strong>Asunto:</strong> ${subject}</p><p><strong>Mensaje:</strong></p><p>${message.replace(/\n/g, '<br>')}</p>`,
            replyTo: email,
          }),
        });

        if (res.ok) {
          status.className = 'cf-status mt-3 text-sm min-h-[1.25rem] text-emerald-400';
          status.textContent = 'Mensaje enviado. Te respondo pronto.';
          form.reset();
        } else {
          const body = await res.json().catch(() => ({}));
          status.className = 'cf-status mt-3 text-sm min-h-[1.25rem] text-rose-400';
          status.textContent = body?.error || 'No se pudo enviar. Intenta mas tarde.';
        }
      } catch {
        status.className = 'cf-status mt-3 text-sm min-h-[1.25rem] text-rose-400';
        status.textContent = 'Error de red. Verifica tu conexion.';
      } finally {
        button.disabled = false;
      }
    });
  });
</script>
