---
/**
 * NewsletterForm — Listmonk public subscription
 * Brand: jotive.dev | Lista: Jotive Dev (UUID 706f4a79-...)
 * Stack tematico: Tailwind dark (zinc-950 / zinc-100)
 *
 * Source compartido: github.com/GeosData/newsletter-stack/snippets/NewsletterForm.astro
 */

interface Props {
  listUuid?: string;
  title?: string;
  description?: string;
  ctaText?: string;
  placeholder?: string;
}

const {
  listUuid = '706f4a79-9254-43fa-b185-5a48c1bc5c46',
  title = 'Bitacora dev semanal',
  description = 'Senior Python + GenAI architecture. Notas reales de produccion. Una vez por semana, sin spam.',
  ctaText = 'Suscribirme',
  placeholder = 'tu@email.com',
} = Astro.props;
---

<section class="border-t border-zinc-800/80 bg-zinc-900/30">
  <div class="max-w-3xl mx-auto px-6 py-14">
    <h3 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-3" style="font-family: var(--font-display);">
      {title}
    </h3>
    <p class="text-zinc-400 mb-6 max-w-xl">{description}</p>

    <form class="newsletter-form flex flex-col sm:flex-row gap-3 max-w-xl" data-list-uuid={listUuid} novalidate>
      <input
        type="email"
        name="email"
        placeholder={placeholder}
        required
        autocomplete="email"
        class="flex-1 px-4 py-3 rounded-lg bg-zinc-950 border border-zinc-700 text-zinc-100 placeholder-zinc-500 focus:outline-none focus:border-sky-500 transition-colors"
      />
      <button
        type="submit"
        class="px-6 py-3 rounded-lg bg-sky-500 hover:bg-sky-400 text-white font-medium transition-colors disabled:opacity-50 disabled:cursor-wait"
      >
        {ctaText}
      </button>
    </form>

    <p class="nl-status mt-3 text-sm min-h-[1.25rem]" role="status" aria-live="polite"></p>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLFormElement>('form.newsletter-form').forEach((form) => {
    const input = form.querySelector<HTMLInputElement>('input[type="email"]')!;
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const status = form.parentElement!.querySelector<HTMLElement>('.nl-status')!;
    const listUuid = form.dataset.listUuid!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = input.value.trim();
      if (!email) return;

      status.className = 'nl-status mt-3 text-sm min-h-[1.25rem] text-zinc-400';
      status.textContent = 'Enviando...';
      button.disabled = true;

      try {
        const res = await fetch('https://newsletter.geosdata.com/api/public/subscription', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, list_uuids: [listUuid] }),
        });

        if (res.ok) {
          status.className = 'nl-status mt-3 text-sm min-h-[1.25rem] text-emerald-400';
          status.textContent = 'Revisa tu email para confirmar la suscripcion.';
          input.value = '';
        } else {
          const data = await res.json().catch(() => ({}));
          status.className = 'nl-status mt-3 text-sm min-h-[1.25rem] text-rose-400';
          status.textContent = data?.message || 'No se pudo procesar. Intenta de nuevo.';
        }
      } catch {
        status.className = 'nl-status mt-3 text-sm min-h-[1.25rem] text-rose-400';
        status.textContent = 'Error de red. Verifica tu conexion.';
      } finally {
        button.disabled = false;
      }
    });
  });
</script>
