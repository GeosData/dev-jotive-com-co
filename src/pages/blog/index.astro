---
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const currentYear = new Date().getFullYear();
const siteUrl = 'https://dev.jotive.com.co';
const blogUrl = `${siteUrl}/blog`;
const ogImage = `${siteUrl}/og-image.svg`;
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Blog de Jotive — artículos prácticos sobre backend, arquitectura de software, Node.js y desarrollo de productos digitales. Tutoriales y aprendizajes de un desarrollador full-stack.">
  <meta name="keywords" content="blog backend, Node.js, TypeScript, arquitectura software, APIs REST, microservicios, desarrollo web, Colombia, tutoriales backend">
  <meta name="author" content="Jotive">
  <meta name="robots" content="index, follow">

  <meta property="og:title" content="Blog | Jotive — Backend, Arquitectura & Node.js">
  <meta property="og:description" content="Artículos prácticos sobre backend, arquitectura de software y Node.js. Aprendizajes de un desarrollador full-stack.">
  <meta property="og:type" content="website">
  <meta property="og:url" content={blogUrl}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="Jotive.dev">
  <meta property="og:locale" content="es_CO">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Blog | Jotive — Backend, Arquitectura & Node.js">
  <meta name="twitter:description" content="Artículos prácticos sobre backend, arquitectura de software y Node.js.">
  <meta name="twitter:image" content={ogImage}>

  <link rel="canonical" href={blogUrl}>
  <title>Blog | Jotive — Backend, Arquitectura & Node.js</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Schema.org Blog -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Blog",
      "name": "Blog de Jotive",
      "description": "Artículos prácticos sobre backend, arquitectura de software y Node.js",
      "url": "https://dev.jotive.com.co/blog",
      "author": {
        "@type": "Person",
        "name": "Jotive",
        "url": "https://dev.jotive.com.co"
      }
    }
  </script>
</head>
<body class="bg-zinc-950 text-zinc-300 font-sans selection:bg-emerald-500/30 selection:text-emerald-200">
  <div class="fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-950/20 via-zinc-950 to-zinc-950 -z-10"></div>

  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-sm">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-mono text-sm text-emerald-400 hover:text-emerald-300 transition-colors">jotive.dev</a>
      <div class="flex items-center gap-6 text-sm text-zinc-400">
        <a href="/#proyectos" class="hover:text-zinc-100 transition-colors">Proyectos</a>
        <span class="text-emerald-400">Blog</span>
        <a href="https://jotive.com.co" class="hover:text-zinc-100 transition-colors">← Volver</a>
      </div>
    </div>
  </nav>

  <main class="max-w-3xl mx-auto px-6 pt-32 pb-24">
    <div class="mb-16">
      <p class="font-mono text-emerald-400 text-sm mb-3">blog</p>
      <h1 class="text-4xl font-bold text-white mb-4">Artículos</h1>
      <p class="text-zinc-400">Aprendizajes prácticos sobre backend, arquitectura de software y construcción de productos digitales. Sin teoría vacía — solo lo que funciona en producción.</p>
    </div>

    <div class="space-y-4">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group flex items-start justify-between gap-6 p-6 rounded-2xl bg-zinc-900/60 border border-zinc-800 hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-0.5"
        >
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap gap-1.5 mb-2">
              {post.data.tags.map((tag) => (
                <span class="px-2 py-0.5 rounded-md bg-zinc-800 text-zinc-500 text-xs font-mono">{tag}</span>
              ))}
            </div>
            <h2 class="font-semibold text-zinc-100 group-hover:text-emerald-400 transition-colors mb-1">{post.data.title}</h2>
            <p class="text-zinc-500 text-sm leading-relaxed">{post.data.description}</p>
          </div>
          <div class="flex flex-col items-end gap-3 shrink-0">
            <time class="font-mono text-xs text-zinc-600">
              {post.data.date.toLocaleDateString('es-CO', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-emerald-400 transform group-hover:-rotate-45 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </div>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-zinc-800/80">
    <div class="max-w-5xl mx-auto px-6 py-8">
      <p class="text-sm text-zinc-600 font-mono">© {currentYear} Jotive · dev.jotive.com.co</p>
    </div>
  </footer>
</body>
</html>
