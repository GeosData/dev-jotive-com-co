---
import '../../styles/global.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Blog de Josse — artículos sobre backend, arquitectura y productos digitales.">
  <title>Blog | jotive.dev</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body class="bg-zinc-950 text-zinc-300 font-sans selection:bg-emerald-500/30 selection:text-emerald-200">
  <div class="fixed inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-950/20 via-zinc-950 to-zinc-950 -z-10"></div>

  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-sm">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <a href="/" class="font-mono text-sm text-emerald-400 hover:text-emerald-300 transition-colors">jotive.dev</a>
      <div class="flex items-center gap-6 text-sm text-zinc-400">
        <a href="/#proyectos" class="hover:text-zinc-100 transition-colors">Proyectos</a>
        <span class="text-emerald-400">Blog</span>
        <a href="https://jotive.com.co" class="hover:text-zinc-100 transition-colors">← Volver</a>
      </div>
    </div>
  </nav>

  <main class="max-w-3xl mx-auto px-6 pt-32 pb-24">
    <div class="mb-16">
      <p class="font-mono text-emerald-400 text-sm mb-3">blog</p>
      <h1 class="text-4xl font-bold text-white mb-4">Artículos</h1>
      <p class="text-zinc-400">Notas sobre backend, arquitectura y productos digitales.</p>
    </div>

    <div class="space-y-4">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="group flex items-start justify-between gap-6 p-6 rounded-2xl bg-zinc-900/60 border border-zinc-800 hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-0.5"
        >
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap gap-1.5 mb-2">
              {post.data.tags.map((tag) => (
                <span class="px-2 py-0.5 rounded-md bg-zinc-800 text-zinc-500 text-xs font-mono">{tag}</span>
              ))}
            </div>
            <h2 class="font-semibold text-zinc-100 group-hover:text-emerald-400 transition-colors mb-1">{post.data.title}</h2>
            <p class="text-zinc-500 text-sm leading-relaxed">{post.data.description}</p>
          </div>
          <div class="flex flex-col items-end gap-3 shrink-0">
            <time class="font-mono text-xs text-zinc-600">
              {post.data.date.toLocaleDateString('es-CO', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <svg class="w-4 h-4 text-zinc-600 group-hover:text-emerald-400 transform group-hover:-rotate-45 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </div>
        </a>
      ))}
    </div>
  </main>

  <footer class="border-t border-zinc-800/80">
    <div class="max-w-5xl mx-auto px-6 py-8">
      <p class="text-sm text-zinc-600 font-mono">© {currentYear} Josse · dev.jotive.com.co</p>
    </div>
  </footer>
</body>
</html>
