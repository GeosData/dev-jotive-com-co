  <!-- Language Switcher Script -->
  <script>
    const STORAGE_KEY = 'jotive-lang';
    const translations = {
      es: {
        'nav.projects': 'Proyectos',
        'nav.blog': 'Blog',
        'nav.back': '← Volver',
        'hero.available': 'Disponible para nuevos proyectos',
        'hero.title': 'Hola, soy',
        'hero.cta': 'Ver proyectos',
        'stack.title': 'Stack',
        'stack.experience': 'Experiencia',
        'stack.familiarity': 'Competente',
        'stack.knowledge': 'Nociones',
        'stack.languages': 'Lenguajes',
        'stack.frameworks': 'Frameworks',
        'stack.dataAndAI': 'Datos e IA',
        'stack.devops': 'DevOps',
        'stack.security': 'Seguridad',
        'projects.title': 'Proyectos',
        'blog.title': 'Blog',
        'blog.viewAll': 'Ver todos →',
      },
      en: {
        'nav.projects': 'Projects',
        'nav.blog': 'Blog',
        'nav.back': '← Back',
        'hero.available': 'Available for new projects',
        'hero.title': "Hi, I'm",
        'hero.cta': 'View projects',
        'stack.title': 'Stack',
        'stack.experience': 'Experience',
        'stack.familiarity': 'Familiar',
        'stack.knowledge': 'Knowledge',
        'stack.languages': 'Languages',
        'stack.frameworks': 'Frameworks',
        'stack.dataAndAI': 'Data & AI',
        'stack.devops': 'DevOps',
        'stack.security': 'Security',
        'projects.title': 'Projects',
        'blog.title': 'Blog',
        'blog.viewAll': 'View all →',
      }
    };

    function getLang() {
      return localStorage.getItem(STORAGE_KEY) || 'es';
    }

    function setLang(lang) {
      localStorage.setItem(STORAGE_KEY, lang);
      document.documentElement.setAttribute('data-lang', lang);
      updateContent(lang);
      document.getElementById('current-lang').textContent = lang.toUpperCase();
    }

    function updateContent(lang) {
      const t = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (t[key]) {
          if (el.hasAttribute('data-i18n-html')) {
            el.innerHTML = t[key];
          } else {
            el.textContent = t[key];
          }
        }
      });
    }

    function toggleLang() {
      const current = getLang();
      const next = current === 'es' ? 'en' : 'es';
      setLang(next);
    }

    // Expose to global scope for onclick handlers
    window.toggleLang = toggleLang;

    // Initialize
    document.getElementById('current-lang').textContent = getLang().toUpperCase();
    updateContent(getLang());
  </script>
