---
import '../styles/global.css';

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Jotive - Ingeniero de Sistemas y desarrollador Full-Stack de Colombia. Backend, productos digitales y lifestyle business desde Medellín.">
  <meta name="keywords" content="ingeniero de sistemas, full-stack, backend, developer, Colombia, Medellín, productos digitales, lifestyle business">
  <meta name="author" content="Josse">
  <meta name="robots" content="index, follow">
  
  <meta property="og:title" content="Jotive | Ingeniero de Sistemas & Full-Stack">
  <meta property="og:description" content="Ingeniero de Sistemas y desarrollador Full-Stack de Colombia. Backend, productos digitales y lifestyle business.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://jotive.com.co">
  <meta property="og:site_name" content="Jotive">
  
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Jotive | Ingeniero de Sistemas & Full-Stack">
  <meta name="twitter:description" content="Ingeniero de Sistemas y desarrollador Full-Stack de Colombia. Backend, productos digitales y lifestyle business.">
  
  <link rel="canonical" href="https://jotive.com.co">
  <link rel="alternate" hreflang="es" href="https://jotive.com.co">
  
  <title>Jotive | Ingeniero de Sistemas & Full-Stack</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-[var(--bg-primary)] text-zinc-300 font-sans selection:bg-emerald-500/30 selection:text-emerald-200 transition-colors duration-300">
  <div class="relative min-h-screen">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-zinc-900/50 via-zinc-950 to-zinc-950 -z-10 light:from-zinc-100/50 light:via-zinc-50 light:to-zinc-50 transition-colors duration-300"></div>

    <button 
      id="theme-toggle" 
      class="fixed top-6 right-6 z-50 p-2.5 rounded-xl bg-zinc-800/80 border border-zinc-700/50 hover:border-zinc-500 text-zinc-400 hover:text-white transition-all duration-300 hover:scale-110 light:bg-white light:border-zinc-200 light:text-zinc-600 light:hover:text-zinc-900"
      aria-label="Cambiar tema"
    >
      <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
      </svg>
      <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
      </svg>
    </button>

    <main class="flex-1 relative z-10">
      <div class="max-w-4xl mx-auto px-6 py-24 md:py-32">
        
        <header class="mb-24 max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-800 text-sm text-zinc-400 mb-6 shadow-sm light:bg-white light:border-zinc-200 light:text-zinc-600 transition-colors duration-300">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            Abierto a conversar sobre nuevos proyectos
          </div>
          
          <h1 class="text-4xl md:text-6xl font-extrabold mb-6 text-white light:text-zinc-900 tracking-tight transition-colors duration-300">
            Hola, soy <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-500">Josse</span>
          </h1>
          
          <p class="text-xl text-zinc-400 light:text-zinc-600 leading-relaxed mb-6 font-light transition-colors duration-300">
            Ingeniero de Sistemas y desarrollador Full-Stack enfocado en el backend. Me dedico a programar y a dar vida a productos digitales que realmente resuelvan problemas.
          </p>
          
          <p class="text-zinc-500 light:text-zinc-500 text-base transition-colors duration-300">
            Trabajo en mis propios proyectos desde Colombia 🇨🇴, buscando siempre un equilibrio entre lo técnico, mis pasiones y la vida diaria. Este es mi pequeño rincón en internet donde agrupo todo lo que hago.
          </p>
        </header>

        <section class="mb-16">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-lg font-semibold text-zinc-100 light:text-zinc-900 transition-colors duration-300">Proyectos principales</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-zinc-800 to-transparent light:from-zinc-300 to-transparent transition-colors duration-300"></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
            
            <a href="https://dev.jotive.com.co" target="_blank" rel="noopener noreferrer" class="group relative md:col-span-3 p-6 md:p-8 rounded-3xl bg-zinc-900/50 border border-zinc-800/50 hover:border-emerald-500/30 overflow-hidden transition-all duration-500 hover:shadow-[0_0_30px_-10px_rgba(16,185,129,0.15)] light:bg-white/50 light:border-zinc-200/50 hover:light:border-emerald-400/30">
              <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="relative z-10 flex flex-col justify-between h-full">
                <div>
                  <div class="flex items-center gap-3 mb-4">
                    <div class="p-2.5 rounded-xl bg-zinc-800/80 text-emerald-400 border border-zinc-700/50 group-hover:scale-110 transition-transform duration-300 light:bg-zinc-100 light:border-zinc-200 light:text-emerald-600">
                      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16.5 9.4 7.55 4.24"/>
                        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                        <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                        <line x1="12" y1="22.08" x2="12" y2="12"/>
                      </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-zinc-100 group-hover:text-emerald-400 transition-colors light:text-zinc-900 light:group-hover:text-emerald-600">Desarrollo</h3>
                  </div>
                  <p class="text-zinc-400 light:text-zinc-600 text-base leading-relaxed transition-colors duration-300">Mi espacio técnico personal. Aquí subo arquitecturas backend, notas de código, experimentos de software y todo lo relacionado con mi lado más "geek".</p>
                </div>
                <div class="mt-6 flex items-center justify-between">
                  <span class="text-xs font-mono text-zinc-500 group-hover:text-emerald-500/70 transition-colors light:text-zinc-400">dev.jotive.com.co</span>
                  <div class="flex h-8 w-8 items-center justify-center rounded-full border border-zinc-700 bg-zinc-800/50 text-zinc-400 group-hover:bg-emerald-500/20 group-hover:text-emerald-400 group-hover:border-emerald-500/30 transition-all duration-300 transform group-hover:-rotate-45 light:border-zinc-300 light:bg-zinc-100 light:text-zinc-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                  </div>
                </div>
              </div>
            </a>

            <a href="https://geosdata.com" target="_blank" rel="noopener noreferrer" class="group relative md:col-span-2 p-6 md:p-8 rounded-3xl bg-zinc-900/50 border border-zinc-800/50 hover:border-sky-500/30 overflow-hidden transition-all duration-500 hover:-translate-y-1 light:bg-white/50 light:border-zinc-200/50 hover:light:border-sky-400/30">
              <div class="absolute inset-0 bg-gradient-to-br from-sky-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="relative z-10 flex flex-col justify-between h-full">
                <div>
                  <div class="flex items-center gap-3 mb-4">
                    <div class="p-2.5 rounded-xl bg-zinc-800/80 text-sky-400 border border-zinc-700/50 group-hover:scale-110 transition-transform duration-300 light:bg-zinc-100 light:border-zinc-200 light:text-sky-600">
                      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                        <polyline points="2 17 12 22 22 17"/>
                        <polyline points="2 12 12 17 22 12"/>
                      </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-zinc-100 group-hover:text-sky-400 transition-colors light:text-zinc-900 light:group-hover:text-sky-600">Geosdata</h3>
                    <span class="text-[10px] px-2 py-0.5 rounded-full bg-sky-500/10 text-sky-400 border border-sky-500/20 uppercase tracking-wider font-semibold ml-auto light:bg-sky-100 light:text-sky-600 light:border-sky-200">Laboratorio</span>
                  </div>
                  <p class="text-zinc-400 light:text-zinc-600 text-sm leading-relaxed mb-4 transition-colors duration-300">Mi laboratorio de ideas. Aquí nacen y se prueban nuevos proyectos.</p>
                </div>
                <div class="mt-4 flex items-center justify-between">
                  <span class="text-xs font-mono text-zinc-500 group-hover:text-sky-500/70 transition-colors light:text-zinc-400">geosdata.com</span>
                  <div class="flex h-8 w-8 items-center justify-center rounded-full text-zinc-500 group-hover:text-sky-400 transition-all duration-300 transform group-hover:-rotate-45 light:text-zinc-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                  </div>
                </div>
              </div>
            </a>

          </div>
        </section>

        <section class="mb-20">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-lg font-semibold text-zinc-100 light:text-zinc-900 transition-colors duration-300">Pasatiempos y experimentación</h2>
            <div class="h-px flex-1 bg-gradient-to-r from-zinc-800 to-transparent light:from-zinc-300 to-transparent transition-colors duration-300"></div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            
            <a href="/blog" class="group relative p-6 rounded-3xl bg-zinc-900/30 border-l-4 border-zinc-500/50 border-t border-r border-zinc-800/30 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1 light:bg-white/30 light:border-zinc-300 light:hover:bg-white/50">
              <div class="flex items-center justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800/50 text-zinc-400 light:bg-zinc-100 light:text-zinc-500">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
                  </svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-zinc-300 transform group-hover:-rotate-45 transition-all light:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
              <h3 class="text-lg font-medium text-zinc-100 group-hover:text-zinc-300 transition-colors light:text-zinc-900 light:group-hover:text-zinc-700 mb-2">Blog</h3>
              <p class="text-zinc-400 light:text-zinc-600 text-sm leading-relaxed transition-colors duration-300">Artículos, aprendizajes y reflexiones sobre desarrollo y tecnología.</p>
            </a>

            <a href="https://edu.jotive.com.co" target="_blank" rel="noopener noreferrer" class="group relative p-6 rounded-3xl bg-zinc-900/30 border-l-4 border-amber-500/50 border-t border-r border-zinc-800/30 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1 light:bg-white/30 light:border-amber-300 light:hover:bg-white/50">
              <div class="flex items-center justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800/50 text-amber-400 light:bg-amber-50 light:text-amber-500">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
                    <circle cx="12" cy="9" r="2"/>
                    <path d="m9 11 2 2 4-4"/>
                  </svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-amber-400 transform group-hover:-rotate-45 transition-all light:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
              <h3 class="text-lg font-medium text-zinc-100 group-hover:text-amber-400 transition-colors light:text-zinc-900 light:group-hover:text-amber-600 mb-2">Educación</h3>
              <p class="text-zinc-400 light:text-zinc-600 text-sm leading-relaxed transition-colors duration-300">Ideas y recursos para que los docentes integren tecnología en el aula, incluso sin internet.</p>
            </a>

            <a href="https://play.jotive.com.co" target="_blank" rel="noopener noreferrer" class="group relative p-6 rounded-3xl bg-zinc-900/30 border-l-4 border-rose-500/50 border-t border-r border-zinc-800/30 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1 light:bg-white/30 light:border-rose-300 light:hover:bg-white/50">
              <div class="flex items-center justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800/50 text-rose-400 light:bg-rose-50 light:text-rose-500">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m8 12 3 3 5-5"/>
                    <path d="M12 8v8"/>
                    <path d="M8 16h8"/>
                    <rect x="4" y="4" width="16" height="16" rx="2"/>
                  </svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-rose-400 transform group-hover:-rotate-45 transition-all light:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
              <h3 class="text-lg font-medium text-zinc-100 group-hover:text-rose-400 transition-colors light:text-zinc-900 light:group-hover:text-rose-600 mb-2">Game Dev</h3>
              <p class="text-zinc-400 light:text-zinc-600 text-sm leading-relaxed transition-colors duration-300">Bitácora de cómo estoy intentando hacer mi propio videojuego 2D de granjas.</p>
            </a>

            <a href="https://tech.jotive.com.co" target="_blank" rel="noopener noreferrer" class="group relative p-6 rounded-3xl bg-zinc-900/30 border-l-4 border-violet-500/50 border-t border-r border-zinc-800/30 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1 light:bg-white/30 light:border-violet-300 light:hover:bg-white/50">
              <div class="flex items-center justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800/50 text-violet-400 light:bg-violet-50 light:text-violet-500">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z"/>
                    <path d="M12 8v8"/>
                    <path d="M8 12h8"/>
                  </svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-violet-400 transform group-hover:-rotate-45 transition-all light:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
              <h3 class="text-lg font-medium text-zinc-100 group-hover:text-violet-400 transition-colors light:text-zinc-900 light:group-hover:text-violet-600 mb-2">Tech</h3>
              <p class="text-zinc-400 light:text-zinc-600 text-sm leading-relaxed transition-colors duration-300">Cacharreo con Raspberry Pi, proyectos de hardware y electrónica básica.</p>
            </a>

            <a href="https://photo.jotive.com.co" target="_blank" rel="noopener noreferrer" class="group relative p-6 rounded-3xl bg-zinc-900/30 border-l-4 border-pink-500/50 border-t border-r border-zinc-800/30 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1 light:bg-white/30 light:border-pink-300 light:hover:bg-white/50">
              <div class="flex items-center justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800/50 text-pink-400 light:bg-pink-50 light:text-pink-500">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
                    <circle cx="12" cy="13" r="3"/>
                  </svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-pink-400 transform group-hover:-rotate-45 transition-all light:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
              <h3 class="text-lg font-medium text-zinc-100 group-hover:text-pink-400 transition-colors light:text-zinc-900 light:group-hover:text-pink-600 mb-2">Photo</h3>
              <p class="text-zinc-400 light:text-zinc-600 text-sm leading-relaxed transition-colors duration-300">Mis fotografías. Paisajes, naturaleza y momentos capturados con mi cámara.</p>
            </a>

            <a href="https://nature.jotive.com.co" target="_blank" rel="noopener noreferrer" class="group relative p-6 rounded-3xl bg-zinc-900/30 border-l-4 border-emerald-500/50 border-t border-r border-zinc-800/30 hover:bg-zinc-900/50 transition-all duration-300 hover:-translate-y-1 light:bg-white/30 light:border-emerald-300 light:hover:bg-white/50">
              <div class="flex items-center justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800/50 text-emerald-400 light:bg-emerald-50 light:text-emerald-500">
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22c4-4 8-7.5 8-12a8 8 0 1 0-16 0c0 4.5 4 8 8 12z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-emerald-400 transform group-hover:-rotate-45 transition-all light:text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </div>
              <h3 class="text-lg font-medium text-zinc-100 group-hover:text-emerald-400 transition-colors light:text-zinc-900 light:group-hover:text-emerald-600 mb-2">Naturaleza</h3>
              <p class="text-zinc-400 light:text-zinc-600 text-sm leading-relaxed transition-colors duration-300">Senderismo, montañas y conexión con el entorno natural.</p>
            </a>

          </div>
        </section>

        <footer class="pt-8 border-t border-zinc-800/80 light:border-zinc-200 flex flex-col md:flex-row items-center justify-between gap-6 transition-colors duration-300">
          <p class="text-sm text-zinc-500 light:text-zinc-500 font-medium transition-colors duration-300">
            © {currentYear} Jotive.
          </p>
          <div class="flex gap-6">
            <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-zinc-500 hover:text-white light:hover:text-zinc-900 hover:-translate-y-0.5 transition-all">
              <span class="sr-only">GitHub</span>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
            </a>
