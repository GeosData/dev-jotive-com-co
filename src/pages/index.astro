---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { translations, type Lang } from '../i18n/translations';

const currentYear = new Date().getFullYear();
const siteUrl = 'https://dev.jotive.com.co';
const ogImage = `${siteUrl}/og-image.svg`;
const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Default language (server-side), client will override
const lang: Lang = 'es';
const t = translations[lang];

const stack = {
  experience: {
    languages: ['Python', 'JavaScript'],
    frameworks: ['FastAPI', 'React', 'Tailwind CSS'],
    databases: ['PostgreSQL', 'MongoDB', 'MySQL', 'Redis'],
    ai: ['LangChain', 'LangGraph', 'OpenAI', 'Qdrant'],
    devops: ['Docker', 'AWS', 'GitHub Actions', 'Git'],
    architecture: ['REST APIs', 'Microservices'],
  },
  familiarity: {
    languages: ['Node.js', 'TypeScript'],
    frameworks: ['Angular', 'Prisma'],
    ai: ['LLMs', 'FAISS', 'Milvus'],
    devops: ['Kubernetes', 'GCP', 'Azure', 'Prometheus', 'Grafana', 'CI/CD'],
    security: ['JWT', 'OAuth', 'API Design'],
  },
  knowledge: {
    devops: ['Nginx'],
    backend: ['Firebase'],
    legacy: ['Java', '.NET', 'PHP'],
  },
};

const projects = [
  {
    name: 'DocuQuery',
    description: 'RAG platform que indexa corpus documentales y responde consultas en lenguaje natural con LLM. Respuestas contextualizadas con referencias a fuentes en segundos. Multi-tenant con cost tracking por request.',
    tags: ['FastAPI', 'PostgreSQL', 'Qdrant', 'Redis', 'Celery', 'OpenAI'],
    url: 'https://github.com/GeosData/llm-rag-platform',
    color: 'emerald',
  },
  {
    name: 'ClaimFlow',
    description: 'Sistema de orquestación multi-step para pipelines de aprobación. Cada agente maneja un paso discreto — extracción, validación, decisión, notificación — con logs de razonamiento completo para auditoría.',
    tags: ['Python', 'LangGraph', 'LangChain', 'ARQ', 'Redis', 'OpenTelemetry'],
    url: 'https://github.com/GeosData/ai-agents-workflow',
    color: 'violet',
  },
  {
    name: 'AIGateway',
    description: 'Gateway multi-tenant que abstrae LLM providers tras API unificada. Model routing, fallback automático, rate limiting por API key, cost tracking y observabilidad completa. Listo para producción en días.',
    tags: ['FastAPI', 'Redis', 'PostgreSQL', 'Prometheus', 'Grafana', 'Tenacity'],
    url: 'https://github.com/GeosData/production-ai-backend',
    color: 'sky',
  },
  {
    name: 'TalentMatch',
    description: 'Servicio de búsqueda semántica de alta performance. Hybrid ranking (BM25 + vector) para capturar intención más allá de keywords. Indexación batch y realtime con filtros de metadata.',
    tags: ['Python', 'FastAPI', 'Qdrant', 'PostgreSQL', 'sentence-transformers'],
    url: 'https://github.com/GeosData/vector-search-api',
    color: 'amber',
  },
  {
    name: 'SmartShop',
    description: 'Backend para PYMEs locales: inventario en tiempo real con alertas WhatsApp, tracking de ventas, gestión de órdenes y forecasting semanal. Multi-tenant con roles (dueño + staff).',
    tags: ['FastAPI', 'PostgreSQL', 'Redis', 'Celery', 'WebSockets', 'Pandas'],
    url: 'https://github.com/GeosData/smartshop',
    color: 'orange',
  },
];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Ingeniero de Sistemas especializado en AI Backend. Construyo sistemas LLM, arquitectura RAG, agentes inteligentes y APIs de búsqueda semántica. Experiencia con LangChain, LangGraph, vector databases y LLMOps. Disponible para proyectos en Colombia y remoto.">
  <meta name="keywords" content="ingeniero de sistemas, AI backend, LLM developer, Python AI, LangChain, LangGraph, RAG architecture, vector search, FAISS, Milvus, OpenAI, FastAPI, agentes AI, embeddings, búsqueda semántica, LLMOps, Colombia, Montería, Córdoba, desarrollador backend, AI engineer">
  <meta name="author" content="Jotive">
  <meta name="robots" content="index, follow, max-image-preview:large">
  <meta name="googlebot" content="index, follow">

  <meta property="og:title" content="Jotive | Ingeniero de Sistemas · AI Backend">
  <meta property="og:description" content="Ingeniero de Sistemas especializado en AI Backend. Construyo sistemas LLM, arquitectura RAG, agentes inteligentes y APIs de búsqueda semántica.">
  <meta property="og:type" content="website">
  <meta property="og:url" content={siteUrl}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="Jotive.dev">
  <meta property="og:locale" content="es_CO">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Jotive | Ingeniero de Sistemas · AI Backend">
  <meta name="twitter:description" content="Ingeniero de Sistemas especializado en AI Backend. Construyo sistemas LLM, arquitectura RAG, agentes inteligentes y APIs de búsqueda semántica.">
  <meta name="twitter:image" content={ogImage}>

  <link rel="canonical" href={siteUrl}>
  <title>Jotive | Ingeniero de Sistemas · AI Backend</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jotive",
      "url": "https://dev.jotive.com.co",
      "jobTitle": "Ingeniero de Sistemas · AI Backend",
      "description": "Ingeniero de Sistemas especializado en AI Backend. Construyo sistemas LLM, arquitectura RAG, agentes inteligentes y APIs de búsqueda semántica.",
      "knowsAbout": ["Python", "FastAPI", "LangChain", "LangGraph", "OpenAI", "RAG", "Vector Databases", "FAISS", "Milvus", "LLM", "AI Agents", "Embeddings", "LLMOps"],
      "sameAs": [
        "https://github.com/jotive",
        "https://linkedin.com/in/jotive",
        "https://twitter.com/jotive"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Jotive"
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Montería",
        "addressRegion": "Córdoba",
        "addressCountry": "CO"
      }
    }
  </script>
</head>
<body class="bg-zinc-950 text-zinc-300 font-sans selection:bg-emerald-500/30 selection:text-emerald-200">
  <div class="relative min-h-screen">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-950/30 via-zinc-950 to-zinc-950 -z-10"></div>

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-sm">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-mono text-sm text-emerald-400 hover:text-emerald-300 transition-colors">jotive.dev</a>
        <div class="flex items-center gap-6 text-sm text-zinc-400">
          <a href="#proyectos" class="hover:text-zinc-100 transition-colors" data-i18n="nav.projects">{t.nav.projects}</a>
          <a href="#blog" class="hover:text-zinc-100 transition-colors" data-i18n="nav.blog">{t.nav.blog}</a>
          <a href="https://jotive.com.co" class="hover:text-zinc-100 transition-colors" data-i18n="nav.back">{t.nav.back}</a>
          
          <!-- Language Toggle -->
          <button 
            id="lang-toggle" 
            class="flex items-center gap-1 px-2 py-1 rounded-md bg-zinc-800 hover:bg-zinc-700 text-xs font-mono transition-colors"
            onclick="toggleLang()"
          >
            <span id="current-lang">ES</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 pt-32 pb-24">

      <!-- Hero -->
      <section class="mb-24">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-sm text-emerald-400 mb-8 font-mono">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span data-i18n="hero.available">{t.hero.available}</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-6">
          <span data-i18n="hero.title">{t.hero.title}</span> <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-400">Jotive</span>
        </h1>

        <p class="text-xl md:text-2xl text-zinc-400 font-light mb-4 max-w-2xl" data-i18n="hero.role">
          <span class="text-zinc-200 font-medium">{t.hero.role}</span>
        </p>

        <p class="text-zinc-500 text-base max-w-xl mb-10 leading-relaxed" data-i18n="hero.location">
          {t.hero.location}
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="#proyectos" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold text-sm transition-all hover:-translate-y-0.5">
            <span data-i18n="hero.cta">{t.hero.cta}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <a href="https://github.com/jotive" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-semibold text-sm border border-zinc-700 transition-all hover:-translate-y-0.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/jotive" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-semibold text-sm border border-zinc-700 transition-all hover:-translate-y-0.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/></svg>
            LinkedIn
          </a>
        </div>
      </section>

      <!-- Stack -->
      <section class="mb-24">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest" data-i18n="stack.title">Stack</h2>
          <div class="h-px flex-1 bg-zinc-800"></div>
        </div>
        
        <div class="space-y-8">
          <!-- Experience -->
          <div>
            <span class="text-xs font-mono text-emerald-500 mb-3 block flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              <span data-i18n="stack.experience">Experiencia</span> (Expert)
            </span>
            <div class="space-y-3">
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.languages">Languages:</span>
                {stack.experience.languages.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.frameworks">Frameworks:</span>
                {stack.experience.frameworks.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.dataAndAI">Data & AI:</span>
                {[...stack.experience.databases, ...stack.experience.ai].map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.devops">DevOps:</span>
                {[...stack.experience.devops, ...stack.experience.architecture].map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
            </div>
          </div>
          
          <!-- Familiarity -->
          <div>
            <span class="text-xs font-mono text-amber-500 mb-3 block flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-amber-500"></span>
              <span data-i18n="stack.familiarity">Competente</span> (Proficient)
            </span>
            <div class="space-y-2">
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.languages">Languages:</span>
                {stack.familiarity.languages.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.frameworks">Frameworks:</span>
                {stack.familiarity.frameworks.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.dataAndAI">Data & AI:</span>
                {[...stack.familiarity.ai, ...stack.familiarity.devops].map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.security">Security:</span>
                {stack.familiarity.security.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
            </div>
          </div>
          
          <!-- Knowledge -->
          <div>
            <span class="text-xs font-mono text-sky-500 mb-3 block flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-sky-500"></span>
              <span data-i18n="stack.knowledge">Nociones</span> (Exposure)
            </span>
            <div class="flex flex-wrap gap-2 items-center">
              {Object.values(stack.knowledge).flat().map((name) => (
                <span class="px-3 py-1.5 rounded-lg bg-zinc-900/50 border border-zinc-800/50 text-zinc-500 text-sm font-mono hover:border-sky-500/40 hover:text-sky-300 transition-all cursor-default">
                  {name}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Proyectos -->
      <section id="proyectos" class="mb-24">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest" data-i18n="projects.title">Proyectos</h2>
          <div class="h-px flex-1 bg-zinc-800"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {projects.map((project) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative p-6 rounded-2xl bg-zinc-900/60 border border-zinc-800 hover:border-emerald-500/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-10px_rgba(16,185,129,0.1)]"
            >
              <div class="flex items-start justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800 text-emerald-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-emerald-400 transform group-hover:-rotate-45 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </div>
              <h3 class="font-semibold text-zinc-100 group-hover:text-emerald-400 transition-colors mb-2">{project.name}</h3>
              <p class="text-zinc-500 text-sm leading-relaxed mb-4">{project.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <span class="px-2 py-0.5 rounded-md bg-zinc-800 text-zinc-500 text-xs font-mono">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Blog -->
      <section id="blog" class="mb-24">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest" data-i18n="blog.title">Blog</h2>
          <div class="h-px flex-1 bg-zinc-800"></div>
          <a href="/blog" class="text-xs font-mono text-zinc-500 hover:text-emerald-400 transition-colors" data-i18n="blog.viewAll">Ver todos →</a>
        </div>
        <div class="space-y-3">
          {recentPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex items-center justify-between gap-4 p-4 rounded-xl bg-zinc-900/60 border border-zinc-800 hover:border-emerald-500/30 transition-all duration-300"
            >
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-zinc-200 group-hover:text-emerald-400 transition-colors truncate">{post.data.title}</h3>
                <p class="text-zinc-600 text-sm truncate">{post.data.description}</p>
              </div>
              <time class="font-mono text-xs text-zinc-600 shrink-0">
                {post.data.date.toLocaleDateString('es-CO', { month: 'short', day: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="border-t border-zinc-800/80 bg-zinc-950">
      <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-zinc-600 font-mono">© {currentYear} Jotive · dev.jotive.com.co</p>
        <div class="flex gap-5">
          <a href="https://github.com/jotive" target="_blank" rel="noopener noreferrer" class="text-zinc-600 hover:text-white transition-colors hover:-translate-y-0.5 inline-block">
