---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { translations, type Lang } from '../i18n/translations';
import NewsletterForm from '../components/NewsletterForm.astro';
import ContactForm from '../components/ContactForm.astro';

const currentYear = new Date().getFullYear();
const siteUrl = 'https://dev.jotive.com.co';
const ogImage = `${siteUrl}/og-image.svg`;
const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Default language (server-side), client will override
const lang: Lang = 'es';
const t = translations[lang];

const stack = {
  experience: {
    languages: ['Python', 'TypeScript', 'JavaScript'],
    frameworks: ['FastAPI', 'Express', 'React', 'Next.js', 'Tailwind CSS'],
    databases: ['PostgreSQL', 'Azure SQL', 'Cosmos DB', 'Redis', 'SQLite'],
    ai: ['OpenAI API', 'Anthropic Claude API'],
    cloud: ['Azure', 'AWS'],
    devops: ['Docker', 'GitHub Actions', 'Azure DevOps', 'Git'],
    architecture: ['REST APIs', 'Microservices', 'Multi-tenant SaaS', 'IaC (bash idempotente)'],
  },
  familiarity: {
    languages: ['Node.js'],
    frameworks: ['Astro', 'Vite', 'Prisma', 'SQLAlchemy 2.0', 'Pydantic v2', 'Alembic'],
    ai: ['LLM application patterns', 'Prompt engineering', 'Vision over remote URLs'],
    cloud: ['GCP'],
    devops: ['Caddy', 'nginx', 'fail2ban', 'systemd', 'OpenTelemetry (en progreso)'],
    security: ['JWT (jose)', 'Google OAuth', 'API key + bearer auth', 'Signed URLs'],
  },
  knowledge: {
    databases: ['MongoDB', 'MySQL', 'Firebase'],
    frameworks: ['Angular'],
    devops: ['Kubernetes', 'Terraform', 'Prometheus', 'Grafana'],
    ai: ['RAG patterns (pgvector)', 'Vector DBs', 'LangChain / LangGraph'],
    legacy: ['Java', '.NET', 'PHP', 'WordPress'],
  },
};

const projects = [
  {
    name: 'Order Processing Platform',
    description: 'Backend production-grade para procesamiento de pedidos. API REST con idempotency dual-layer (Redis + unique constraint), cursor pagination, token bucket rate limiting atómico vía Lua, read-through cache, logs JSON estructurados con correlation IDs. Cada decisión documentada como ADR.',
    tags: ['Python 3.12', 'FastAPI', 'PostgreSQL 16', 'Redis 7', 'SQLAlchemy 2.0', 'Alembic', 'Docker', 'GitHub Actions'],
    url: 'https://github.com/jotive/order-processing-platform',
    color: 'emerald',
    featured: true,
    status: 'WIP',
  },
  {
    name: 'Coding Interviews Prep',
    description: 'Problemas de entrevistas técnicas para roles Senior Backend. Python 3.11+ con pytest y análisis de complejidad O(t)/O(s). Foco: trade-offs explícitos sobre código clever, y explicabilidad en 2 minutos.',
    tags: ['Python', 'pytest', 'Algorithms', 'Trade-offs'],
    url: 'https://github.com/jotive/coding-interviews-prep',
    color: 'sky',
  },
  {
    name: 'Network Scanner',
    description: 'CLI cross-platform (Windows / Linux / macOS) para escanear la red local y detectar dispositivos desconocidos. Sin dependencias externas, Python 3 puro.',
    tags: ['Python', 'CLI', 'Networking', 'Cross-platform'],
    url: 'https://github.com/jotive/network-scanner',
    color: 'sky',
  },
  {
    name: 'System Design Notes',
    description: 'Cuaderno técnico de problemas clásicos de system design. Cada caso con requirements, back-of-envelope estimate, deep dives y alternativas rechazadas. La misma disciplina ADR aplicada al estudio.',
    tags: ['System Design', 'Architecture', 'Trade-offs', 'EN'],
    url: 'https://github.com/jotive/system-design-notes',
    color: 'amber',
    status: 'WIP',
  },
];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Senior Backend Engineer · Python + TypeScript con integración LLM real. Bitácora técnica de APIs en producción con FastAPI, microservicios multi-tenant en Cloud Run, integraciones Claude/OpenAI con quota-aware pipelines, e infraestructura como código.">
  <meta name="keywords" content="senior backend engineer, Python, FastAPI, TypeScript, AI integration, LLM, OpenAI, Anthropic Claude, microservices, PostgreSQL, Redis, Docker, GCP Cloud Run, multi-tenant SaaS, IaC, APIs, Colombia, remote">
  <meta name="author" content="Jotive">
  <meta name="robots" content="index, follow, max-image-preview:large">
  <meta name="googlebot" content="index, follow">

  <meta property="og:title" content="Jotive.dev — Backend + AI · Bitácora técnica">
  <meta property="og:description" content="Notas técnicas y proyectos: APIs en producción con FastAPI, microservicios multi-tenant en Cloud Run, integración LLM con quota-aware pipelines.">
  <meta property="og:type" content="website">
  <meta property="og:url" content={siteUrl}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:site_name" content="Jotive.dev">
  <meta property="og:locale" content="es_CO">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Jotive.dev — Backend + AI · Bitácora técnica">
  <meta name="twitter:description" content="Notas técnicas y proyectos: APIs en producción con FastAPI, microservicios multi-tenant en Cloud Run, integración LLM con quota-aware pipelines.">
  <meta name="twitter:image" content={ogImage}>

  <link rel="canonical" href={siteUrl}>
  <title>Jotive.dev — Backend + AI · Bitácora técnica</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Jotive",
      "url": "https://dev.jotive.com.co",
      "jobTitle": "Senior Backend Engineer · Python + AI Integration",
      "description": "Backend engineer enfocado en producción real. APIs con idempotency, rate limiting Redis Lua atómico, microservicios multi-tenant en Cloud Run, integración LLM con quota-aware pipelines. Decisiones documentadas como ADR.",
      "knowsAbout": ["Python", "FastAPI", "TypeScript", "Node.js", "Express", "Next.js", "OpenAI API", "Anthropic Claude API", "PostgreSQL", "Redis", "Docker", "GCP Cloud Run", "Microservices", "Multi-tenant SaaS", "IaC", "LLM Integration", "API Design", "ADR"],
      "sameAs": [
        "https://github.com/jotive",
        "https://linkedin.com/in/jotive",
        "https://twitter.com/jotive"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Jotive"
      },
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "CO"
      }
    }
  </script>
</head>
<body class="bg-zinc-950 text-zinc-300 font-sans selection:bg-emerald-500/30 selection:text-emerald-200">
  <div class="relative min-h-screen">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-950/30 via-zinc-950 to-zinc-950 -z-10"></div>

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-zinc-800/50 bg-zinc-950/80 backdrop-blur-sm">
      <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
        <a href="/" class="font-mono text-sm text-emerald-400 hover:text-emerald-300 transition-colors">jotive.dev</a>
        <div class="flex items-center gap-6 text-sm text-zinc-400">
          <a href="#proyectos" class="hover:text-zinc-100 transition-colors" data-i18n="nav.projects">{t.nav.projects}</a>
          <a href="#blog" class="hover:text-zinc-100 transition-colors" data-i18n="nav.blog">{t.nav.blog}</a>
          <a href="https://jotive.com.co" class="hover:text-zinc-100 transition-colors" data-i18n="nav.back">{t.nav.back}</a>
          
          <!-- Language Toggle -->
          <button 
            id="lang-toggle" 
            class="flex items-center gap-1 px-2 py-1 rounded-md bg-zinc-800 hover:bg-zinc-700 text-xs font-mono transition-colors"
            onclick="toggleLang()"
          >
            <span id="current-lang">ES</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 pt-32 pb-24">

      <!-- Hero -->
      <section class="mb-24 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-sm text-emerald-400 mb-8 font-mono">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
          </span>
          <span data-i18n="hero.available">{t.hero.available}</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold text-white tracking-tight mb-6">
          <span data-i18n="hero.title">{t.hero.title}</span> <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-teal-400">Jotive</span>
        </h1>

        <p class="text-xl md:text-2xl text-zinc-400 font-light mb-4" data-i18n="hero.role">
          <span class="text-zinc-200 font-medium">{t.hero.role}</span>
        </p>

        <p class="text-zinc-500 text-base mb-10 leading-relaxed" data-i18n="hero.location">
          {t.hero.location}
        </p>

        <div class="flex flex-wrap gap-3">
          <a href="#proyectos" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-emerald-500 hover:bg-emerald-400 text-zinc-950 font-semibold text-sm transition-all hover:-translate-y-0.5">
            <span data-i18n="hero.cta">{t.hero.cta}</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </a>
          <a href="https://github.com/jotive" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-semibold text-sm border border-zinc-700 transition-all hover:-translate-y-0.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/jotive" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-semibold text-sm border border-zinc-700 transition-all hover:-translate-y-0.5">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/></svg>
            LinkedIn
          </a>
        </div>
        </div>

        <!-- Hero right column — code snippet card -->
        <div class="lg:col-span-5">
          <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/80 shadow-[0_8px_40px_-12px_rgba(16,185,129,0.15)] backdrop-blur-sm overflow-hidden">
            <!-- Terminal chrome -->
            <div class="flex items-center justify-between px-4 py-2.5 bg-zinc-900 border-b border-zinc-800">
              <div class="flex items-center gap-1.5">
                <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-zinc-700"></span>
              </div>
              <span class="font-mono text-xs text-zinc-500">order-processing-platform / orders.py</span>
              <span class="font-mono text-[10px] text-emerald-400/70 uppercase tracking-wider">ADR-004</span>
            </div>

            <!-- Code body -->
            <pre class="px-5 py-5 font-mono text-[13px] leading-relaxed text-zinc-300 overflow-x-auto"><code><span class="text-zinc-600"># Idempotency dual-layer: Redis lock + Postgres unique</span>
<span class="text-emerald-400">@router.post</span>(<span class="text-amber-300">"/orders"</span>, status_code=<span class="text-sky-300">201</span>)
<span class="text-emerald-400">async def</span> <span class="text-white">create_order</span>(
    payload: OrderIn,
    idem_key: <span class="text-zinc-400">str</span> = Header(...),
):
    <span class="text-emerald-400">async with</span> redis_lock(idem_key, ttl=<span class="text-sky-300">600</span>):
        <span class="text-emerald-400">try</span>:
            <span class="text-emerald-400">return await</span> orders.insert(payload, idem_key)
        <span class="text-emerald-400">except</span> UniqueViolation:
            <span class="text-zinc-600"># replay tardío — devolver existente</span>
            <span class="text-emerald-400">return await</span> orders.fetch_by_key(idem_key)</code></pre>

            <!-- Footer caption -->
            <div class="flex items-center justify-between px-5 py-3 bg-zinc-900/50 border-t border-zinc-800 font-mono text-xs">
              <span class="text-zinc-500" data-i18n="hero.code.caption">Patrón en producción</span>
              <a href="/blog/" class="text-emerald-400 hover:text-emerald-300 transition-colors" data-i18n="hero.code.link">leer post →</a>
            </div>
          </div>
        </div>
      </section>

      <!-- Stack -->
      <section class="mb-24">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest" data-i18n="stack.title">Stack</h2>
          <div class="h-px flex-1 bg-zinc-800"></div>
        </div>
        
        <div class="space-y-8">
          <!-- Experience -->
          <div>
            <span class="text-xs font-mono text-emerald-500 mb-3 block flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
              <span data-i18n="stack.experience">Experiencia</span> (Expert)
            </span>
            <div class="space-y-3">
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.languages">Languages:</span>
                {stack.experience.languages.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.frameworks">Frameworks:</span>
                {stack.experience.frameworks.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.dataAndAI">Data & AI:</span>
                {[...stack.experience.databases, ...stack.experience.ai].map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.cloud">Cloud:</span>
                {stack.experience.cloud.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.devops">DevOps:</span>
                {[...stack.experience.devops, ...stack.experience.architecture].map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-300 text-sm font-mono hover:border-emerald-500/40 hover:text-emerald-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Familiarity -->
          <div>
            <span class="text-xs font-mono text-amber-500 mb-3 block flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-amber-500"></span>
              <span data-i18n="stack.familiarity">Competente</span> (Proficient)
            </span>
            <div class="space-y-2">
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.languages">Languages:</span>
                {stack.familiarity.languages.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.frameworks">Frameworks:</span>
                {stack.familiarity.frameworks.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.dataAndAI">Data & AI:</span>
                {stack.familiarity.ai.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.cloud">Cloud:</span>
                {stack.familiarity.cloud.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.devops">DevOps:</span>
                {stack.familiarity.devops.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2 items-center">
                <span class="text-xs text-zinc-600 mr-2" data-i18n="stack.security">Security:</span>
                {stack.familiarity.security.map((name) => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-400 text-sm font-mono hover:border-amber-500/40 hover:text-amber-300 transition-all cursor-default">
                    {name}
                  </span>
                ))}
              </div>
            </div>
          </div>
          
          <!-- Knowledge -->
          <div>
            <span class="text-xs font-mono text-sky-500 mb-3 block flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-sky-500"></span>
              <span data-i18n="stack.knowledge">Nociones</span> (Exposure)
            </span>
            <div class="flex flex-wrap gap-2 items-center">
              {Object.values(stack.knowledge).flat().map((name) => (
                <span class="px-3 py-1.5 rounded-lg bg-zinc-900/50 border border-zinc-800/50 text-zinc-500 text-sm font-mono hover:border-sky-500/40 hover:text-sky-300 transition-all cursor-default">
                  {name}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Proyectos -->
      <section id="proyectos" class="mb-24">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest" data-i18n="projects.title">Proyectos</h2>
          <div class="h-px flex-1 bg-zinc-800"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {projects.map((project) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                "group relative p-6 rounded-2xl bg-zinc-900/60 border transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-10px_rgba(16,185,129,0.1)]",
                (project as any).featured
                  ? "md:col-span-2 border-emerald-500/40 bg-gradient-to-br from-emerald-950/40 via-zinc-900/60 to-zinc-900/60 hover:border-emerald-400/60"
                  : "border-zinc-800 hover:border-emerald-500/30"
              ]}
            >
              {(project as any).featured && (
                <div class="flex items-center gap-2 mb-4">
                  <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-emerald-500/15 border border-emerald-500/30 text-emerald-300 text-[10px] font-mono uppercase tracking-wider">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                    Flagship
                  </span>
                  {(project as any).status && (
                    <span class="px-2.5 py-0.5 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-300 text-[10px] font-mono uppercase tracking-wider">
                      {(project as any).status}
                    </span>
                  )}
                </div>
              )}
              <div class="flex items-start justify-between mb-3">
                <div class="p-2 rounded-lg bg-zinc-800 text-emerald-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                </div>
                <svg class="w-4 h-4 text-zinc-600 group-hover:text-emerald-400 transform group-hover:-rotate-45 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
              </div>
              <h3 class:list={[
                "font-semibold group-hover:text-emerald-400 transition-colors mb-2",
                (project as any).featured ? "text-xl text-white" : "text-zinc-100"
              ]}>{project.name}</h3>
              <p class:list={[
                "text-sm leading-relaxed mb-4",
                (project as any).featured ? "text-zinc-400" : "text-zinc-500"
              ]}>{project.description}</p>
              <div class="flex flex-wrap gap-1.5 mb-3">
                {project.tags.map((tag) => (
                  <span class="px-2 py-0.5 rounded-md bg-zinc-800 text-zinc-500 text-xs font-mono">{tag}</span>
                ))}
              </div>
              {'demo' in project && (project as any).demo && (
                <a
                  href={(project as any).demo}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-400 text-xs font-medium border border-emerald-500/20 hover:bg-emerald-500/20 transition-colors"
                  onclick="event.stopPropagation()"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                  Live Demo
                </a>
              )}
            </a>
          ))}
        </div>
      </section>

      <!-- Blog -->
      <section id="blog" class="mb-24">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-sm font-mono text-zinc-500 uppercase tracking-widest" data-i18n="blog.title">Blog</h2>
          <div class="h-px flex-1 bg-zinc-800"></div>
          <a href="/blog" class="text-xs font-mono text-zinc-500 hover:text-emerald-400 transition-colors" data-i18n="blog.viewAll">Ver todos →</a>
        </div>
        <div class="space-y-3">
          {recentPosts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="group flex items-center justify-between gap-4 p-4 rounded-xl bg-zinc-900/60 border border-zinc-800 hover:border-emerald-500/30 transition-all duration-300"
            >
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-zinc-200 group-hover:text-emerald-400 transition-colors truncate">{post.data.title}</h3>
                <p class="text-zinc-600 text-sm truncate">{post.data.description}</p>
              </div>
              <time class="font-mono text-xs text-zinc-600 shrink-0">
                {post.data.date.toLocaleDateString('es-CO', { month: 'short', day: 'numeric' })}
              </time>
            </a>
          ))}
        </div>
      </section>

    </main>

    <!-- Newsletter -->
    <NewsletterForm />
    <ContactForm />

    <!-- Footer -->
    <footer class="border-t border-zinc-800/80 bg-zinc-950">
      <div class="max-w-5xl mx-auto px-6 py-8 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-zinc-600 font-mono">© {currentYear} Jotive · dev.jotive.com.co</p>
        <div class="flex gap-5">
          <a href="https://github.com/jotive" target="_blank" rel="noopener noreferrer" class="text-zinc-600 hover:text-white transition-colors hover:-translate-y-0.5 inline-block">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/></svg>
          </a>
          <a href="https://twitter.com/jotive" target="_blank" rel="noopener noreferrer" class="text-zinc-600 hover:text-sky-400 transition-colors hover:-translate-y-0.5 inline-block">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"/></svg>
          </a>
          <a href="https://linkedin.com/in/jotive" target="_blank" rel="noopener noreferrer" class="text-zinc-600 hover:text-blue-500 transition-colors hover:-translate-y-0.5 inline-block">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </footer>
  </div>

  <!-- Language Switcher Script -->
  <script>
    const STORAGE_KEY = 'jotive-lang';
    const translations = {
      es: {
        'nav.projects': 'Proyectos',
        'nav.blog': 'Blog',
        'nav.back': '← Volver',
        'hero.available': 'Notas técnicas · Backend + AI',
        'hero.title': 'Hola, soy',
        'hero.cta': 'Ver proyectos',
        'hero.code.caption': 'Patrón en producción',
        'hero.code.link': 'leer post →',
        'stack.title': 'Stack',
        'stack.experience': 'Experiencia',
        'stack.familiarity': 'Competente',
        'stack.knowledge': 'Nociones',
        'stack.languages': 'Lenguajes',
        'stack.frameworks': 'Frameworks',
        'stack.dataAndAI': 'Datos e IA',
        'stack.devops': 'DevOps',
        'stack.security': 'Seguridad',
        'projects.title': 'Proyectos',
        'blog.title': 'Blog',
        'blog.viewAll': 'Ver todos →',
      },
      en: {
        'nav.projects': 'Projects',
        'nav.blog': 'Blog',
        'nav.back': '← Back',
        'hero.available': 'Engineering notes · Backend + AI',
        'hero.title': "Hi, I'm",
        'hero.cta': 'View projects',
        'hero.code.caption': 'Pattern in production',
        'hero.code.link': 'read post →',
        'stack.title': 'Stack',
        'stack.experience': 'Experience',
        'stack.familiarity': 'Familiar',
        'stack.knowledge': 'Knowledge',
        'stack.languages': 'Languages',
        'stack.frameworks': 'Frameworks',
        'stack.dataAndAI': 'Data & AI',
        'stack.devops': 'DevOps',
        'stack.security': 'Security',
        'projects.title': 'Projects',
        'blog.title': 'Blog',
        'blog.viewAll': 'View all →',
      }
    };

    function getLang() {
      return localStorage.getItem(STORAGE_KEY) || 'es';
    }

    function setLang(lang) {
      localStorage.setItem(STORAGE_KEY, lang);
      document.documentElement.setAttribute('data-lang', lang);
      updateContent(lang);
      document.getElementById('current-lang').textContent = lang.toUpperCase();
    }

    function updateContent(lang) {
      const t = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (t[key]) {
          if (el.hasAttribute('data-i18n-html')) {
            el.innerHTML = t[key];
          } else {
            el.textContent = t[key];
          }
        }
      });
    }

    function toggleLang() {
      const current = getLang();
      const next = current === 'es' ? 'en' : 'es';
      setLang(next);
    }

    // Expose to global scope for onclick handlers
    window.toggleLang = toggleLang;

    // Initialize
    document.getElementById('current-lang').textContent = getLang().toUpperCase();
    updateContent(getLang());
  </script>
</body>
